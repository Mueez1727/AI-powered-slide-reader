# ============================================
# Multimodal AI-Powered Conversational Slide Reader
# Root Environment Variables
# ============================================

# General
NODE_ENV=development
LOG_LEVEL=debug

# Frontend (Vite prefix required)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_TITLE=Slide Reader AI

# Node.js Backend
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/slide-reader?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
AI_SERVER_URL=http://localhost:8000
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Python AI Server
AI_PORT=8000
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
EMBEDDING_MODEL=all-MiniLM-L6-v2
WHISPER_MODEL=base
TESSERACT_CMD=tesseract
FAISS_INDEX_DIR=./faiss_indices
